spring.application.name=aqi-backend
server.port=8080

spring.datasource.url=jdbc:mysql://localhost:3306/dbname
spring.datasource.username=root
spring.datasource.password=${MYSQL_PASSWORD:CHANGE_ME}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.open-in-view=false
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.time_zone=UTC

aqi.openmeteo.air-quality-url=https://air-quality-api.open-meteo.com/v1/air-quality
aqi.openmeteo.geocoding-url=https://geocoding-api.open-meteo.com/v1/search
aqi.reverse-geocode-url=https://api.bigdatacloud.net/data/reverse-geocode-client

aqi.refresh-interval-ms=600000
aqi.point-cache-ttl-seconds=600
aqi.trend-cache-ttl-seconds=1800
aqi.batch-size=100
aqi.cors-allowed-origins=http://localhost:5173,http://localhost:5174

logging.level.com.bayumandal.aqi=INFO
